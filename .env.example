SECRET_KEY=change-moi-en-production
# Laisser vide en local (SQLite utilise par defaut).
# En production/cloud, renseigner l'URL de la base PostgreSQL, ex:
# DATABASE_URL=postgresql://utilisateur:motdepasse@hote:5432/nom_base
DATABASE_URL=

# Compte administrateur cree automatiquement au premier demarrage (a changer ensuite).
ADMIN_EMAIL_DEFAUT=admin@stock.local
ADMIN_MOTDEPASSE_DEFAUT=admin123

# Notifications email des alertes de stock (optionnel : laisser MAIL_SERVEUR vide
# pour un mode "console" sans envoi reel).
MAIL_SERVEUR=
MAIL_PORT=587
MAIL_UTILISATEUR=
MAIL_MOT_DE_PASSE=
MAIL_EXPEDITEUR=stock@local
MAIL_USE_TLS=1
